# Supabase（Phase 1 建立、SQL Editor 套用 0001/0002/seed）
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 本期 app 走 service_role（繞過 RLS）。未來加登入時才會用到 anon key：
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL token 輕量門禁（修訂 A：本期不做正式登入）。存取網址需帶 ?token=<APP_ACCESS_TOKEN>
APP_ACCESS_TOKEN=openbeauty

# Phase 6+：真實平台觸發（留空 = mock 模式，route 直接寫 Supabase 供 demo）
PLATFORM_API_BASE=
PLATFORM_API_KEY=
